// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "vim_mode": true,
  "diff_view_style": "unified",
  "cli_default_open_behavior": "new_window",
  "icon_theme": {
    "mode": "dark",
    "light": "Base Charmed Icons",
    "dark": "Base Charmed Icons",
  },
  "session": {
    "trust_all_worktrees": true,
  },
  "terminal": {
    "font_size": 12.0,
    "font_family": "JetBrainsMonoNL Nerd Font Mono",
    "line_height": {
      "custom": 1.3,
    },
  },
  "base_keymap": "VSCode",
  "search": {
    "include_ignored": true,
  },
  "minimap": {
    "show": "never",
  },
  "file_types": {
    "php": ["*.module"],
  },
  "ensure_final_newline_on_save": true,
  "remove_trailing_whitespace_on_save": false,
  "ui_font_size": 15.0,
  "buffer_font_family": "Hack Nerd Font Mono",
  "buffer_font_size": 12.0,
  "buffer_line_height": {
    "custom": 2.4,
  },
  "theme": {
    "mode": "dark",
    "light": "One Light",
    "dark": "Peacocks in Space",
  },
  "languages": {
    "Python": {
      "format_on_save": "off",
    },
    "PHP": {
      "language_servers": ["intelephense", "!phpactor", "!phptools", "..."],
      // run laravel pint on save
      "formatter": {
        "external": {
          "command": "bash",
          "arguments": [
            "-c",
            "cat > {buffer_path} && ./vendor/bin/pint --quiet {buffer_path} && cat {buffer_path}",
          ],
        },
        // "external": {
        //   "command": "mago",
        //   "arguments": [
        //     "format",
        //     "--stdin-input",
        //     "--stdin-filepath",
        //     "{buffer_path}",
        //   ],
        // },
      },
    },
  },
  // Theme Overrides
  "theme_overrides": {
    "Peacocks in Space": {
      "border.variant": "#272A33",
      "border": "#272A33",
      "title_bar.background": "#272A33",
      "panel.background": "#272A33",
      "panel.focused_border": "#272A33",
    },
  },
  // UI Cleaning
  "title_bar": {
    "show_onboarding_banner": false,
    "show_branch_name": false,
    // "show_project_items": false,
    "show_user_menu": false,
  },
  "tab_bar": {
    // "show": false,
  },
  "toolbar": {
    "quick_actions": false,
  },
  "project_panel": {
    "default_width": 350,
    "auto_fold_dirs": false,
    "starts_open": false,
    "git_status": false,
    "sticky_scroll": false,
    "scrollbar": {
      "show": "never",
    },
    "indent_guides": {
      "show": "never",
    },
  },
  "outline_panel": {
    "default_width": 300,
    "indent_guides": {
      "show": "never",
    },
  },
  "file_finder": {
    "modal_max_width": "large",
  },
  "scrollbar": {
    // "show": "never",
  },
  "gutter": {
    "min_line_number_digits": 0,
    // "folds": true,
    "runnables": false,
  },
  "indent_guides": {
    "enabled": false,
  },
}
